# Dependencias (no se usan: Three.js está vendorizado en libs/)
node_modules/

# Sistema / editor
.DS_Store
Thumbs.db
*.log
.vscode/
.idea/

# Temporales / outputs de herramientas (defensa genérica; este proyecto no usa bundler)
*.tmp
dist/
coverage/
.cache/
.vite/
__pycache__/
*.pyc

# Backups locales de modelos 3D ORIGINALES sin optimizar (~37 MB): se quedan SOLO en esta PC.
# El repo versiona los .glb optimizados de runtime; los originales no hacen falta para clonar/jugar.
assets/models/characters/*/_backup/

# Materiales de trabajo para la ficha de Play Store (imágenes crudas, ~13 MB): no son runtime.
# Las versiones curadas viven en playstore/assets/.
imagenes/

# Firebase: la config web NO es secreta (se sirve al cliente; la seguridad la dan las
# reglas de Firestore + Auth). El repo trae src/config/firebaseConfig.js con placeholders.
# Si PREFIERES no versionar tus valores reales, descomenta la línea siguiente y ejecuta
# una vez:  git rm --cached src/config/firebaseConfig.js
# src/config/firebaseConfig.js
#
# NUNCA subas claves del Admin SDK / cuentas de servicio (esas SÍ son secretas):
*serviceAccount*.json
*firebase-adminsdk*.json
.env
.env.*

# --- Android / Capacitor ---
# Build web para Capacitor (se regenera con `npm run build`):
www/
# Proyecto Android nativo COMPLETO: es generado/regenerable con `npm run cap:add` +
# `npm run cap:sync`. No se versiona para mantener el repo web limpio y, sobre todo, para
# que NUNCA pueda colarse un secreto nativo (google-services.json, keystore.properties,
# local.properties, config de firma, etc.). Re-crearlo: ver docs/android-build.md.
android/
# (Defensa en profundidad por si algún día se versiona android/ de forma curada:)
android/app/build/
android/build/
android/.gradle/
android/captures/
android/local.properties
android/app/release/
android/app/debug/
android/.idea/
google-services.json
GoogleService-Info.plist
android/keystores/

# --- Firma / secretos / binarios firmados (NUNCA al repo) ---
*.keystore
*.jks
*.p12
*.pem
*.aab
*.apk
keystore.properties
key.properties
local.properties
serviceAccount*.json
*firebase-adminsdk*.json
secrets/
playstore/private/
